{
  "name": "msm-web-app",
  "version": "1.4.0",
  "exports": "./main.ts",
  "tasks": {
    "start": "deno run --unstable-kv --allow-net --allow-read --allow-write --allow-env main.ts",
    "dev": "deno run --watch --unstable-kv --allow-net --allow-read --allow-write --allow-env main.ts",
    "set-password": "deno run --unstable-kv --allow-read --allow-write --allow-env scripts/set-password.ts",
    "reset": "deno run --unstable-kv --allow-read --allow-write --allow-env scripts/reset-db.ts",
    "import-lessons": "deno run --unstable-kv --allow-net --allow-read --allow-write --allow-env scripts/import-lessons.ts"
  },
  "imports": {
    "@std/http": "jsr:@std/http@^1.0.13"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
